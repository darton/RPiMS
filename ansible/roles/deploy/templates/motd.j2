
export TERM=xterm-256color
IFS='; '
SENSOR=$(redis-cli keys \*|grep BME280|head -n 1)
SENSOR_TEMP="$(redis-cli hget $SENSOR temperature)°C"
SENSOR_HUM="$(redis-cli hget $SENSOR humidity)%"
SENSOR_PRESSURE="$(redis-cli hget $SENSOR pressure)hPa"
CPU_TEMP=$(vcgencmd measure_temp|awk -F[=\'] '{print $2"°C"}')

echo "$(tput setaf 2)
   .~~.   .~~.
  '. \ ' ' / .'$(tput setaf 1)
   .~ .~~~..~.
  : .~.'~'.~. :$(tput sgr0)  R P i M S - https://github.com/darton/RPiMS$(tput setaf 1)
~ (   ) (   ) ~  $(tput sgr0)Room Pressure.....: $SENSOR_PRESSURE$(tput setaf 1)
( : '~'.~.'~' : )$(tput sgr0)Room Humidity.....: $SENSOR_HUM$(tput setaf 1)
 ~ .~ (   ) ~. ~ $(tput sgr0)Room Temperature..: $SENSOR_TEMP$(tput setaf 1)
  (  : '~' :  )  $(tput sgr0)CPU Temperature...: $CPU_TEMP$(tput setaf 1)
   '~ .~~~. ~'
       '~'
$(tput sgr0)"

echo

_IP=$(hostname -I) || true
if [ "$_IP" ]; then
  printf "RPiMS address is %s\n" "$_IP"
fi
